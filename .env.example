# Kairo AI — OpenAI-compatible (OpenAI, OpenRouter, etc.)
# Copy to `.env` and fill values. Restart Expo after changes.

# mock = scripted agents (default, no key needed)
# live = call chat completions API
EXPO_PUBLIC_AI_MODE=mock

# OpenRouter
EXPO_PUBLIC_AI_BASE_URL=https://openrouter.ai/api/v1
EXPO_PUBLIC_AI_API_KEY=
EXPO_PUBLIC_AI_MODEL=openai/gpt-4o-mini

# Or OpenAI:
# EXPO_PUBLIC_AI_BASE_URL=https://api.openai.com/v1
# EXPO_PUBLIC_AI_API_KEY=sk-...
# EXPO_PUBLIC_AI_MODEL=gpt-4o-mini

# mem0 — shared agent memory (Phase 9). Optional; local mock used without key.
# https://app.mem0.ai
EXPO_PUBLIC_MEM0_API_KEY=
EXPO_PUBLIC_MEM0_BASE_URL=https://api.mem0.ai
# EXPO_PUBLIC_MEM0_ENABLED=true

# Laminar (official SDK — https://laminar.sh/docs)
# Platform setup:
#   import { Laminar } from '@lmnr-ai/lmnr'
#   Laminar.initialize()  // or pass projectApiKey
#
# Project API key from https://www.lmnr.ai → project settings
EXPO_PUBLIC_LMNR_PROJECT_API_KEY=
# Optional (also accepted by SDK as LMNR_PROJECT_API_KEY)
# LMNR_PROJECT_API_KEY=
# EXPO_PUBLIC_LMNR_BASE_URL=https://api.lmnr.ai

# Optional: force Expo Go QR host when LAN auto-detect fails (phone must reach this host).
# Example: 192.168.1.42:8081
# EXPO_PUBLIC_DEV_SERVER_HOST=

# agentOS local VM bridge (per-agent isolation)
# Start: npm run agentos:install && npm run agentos
EXPO_PUBLIC_AGENTOS_URL=http://localhost:6420

