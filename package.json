{
  "name": "kairo",
  "version": "1.0.0",
  "private": true,
  "description": "Kairo — observability for autonomous software engineering (Expo multi-agent workspace)",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
